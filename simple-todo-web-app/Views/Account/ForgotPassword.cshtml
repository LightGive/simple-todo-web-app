@model simple_todo_web_app.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "パスワードの再設定";
}

<div class="text-center mt-5">
    <h1>パスワードの再設定</h1>
    <p class="mt-3">
        登録済みのメールアドレスを入力してください。<br />
        パスワード再設定用のURLをお送りします。
    </p>
    <form method="post"
          asp-action="ForgotPassword"
          asp-controller="Account"
          class="container mt-4">

        <!-- メールアドレス入力フォーム -->
        <div class="row mb-2">
            <label for="forgot-email-address" class="col form-label">
                メールアドレス
            </label>
            <input type="email"
                   id="forgot-email-address"
                   asp-for="Email"
                   class="form-control col"
                   placeholder="xxx@example.jp" />
        </div>

        <!-- バリデーション結果表示 -->
        <div id="validation-container" class="alert alert-primary mb-4" role="alert" style="display:none">
            <div asp-validation-summary="All"></div>
        </div>

        <!-- 送信ボタン -->
        <button type="submit" class="btn btn-primary">再設定メールを送信する</button>

        <!-- 各リンク -->
        <div class="mt-4">
            <a href="/account/login" class="link-primary">ログイン画面に戻る</a>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_FormValidation")
}
